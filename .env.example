# Private key for the wallet that will receive USDC payments on Base network
# Get this from your wallet (never commit real private keys to git)
PINION_PRIVATE_KEY=your_private_key_here

# Default target API URL (can be overridden via CLI)
DEFAULT_TARGET=http://localhost:3000

# Default price per API call in USDC
DEFAULT_PRICE=0.01

# Default port for the proxy server
DEFAULT_PORT=4000
