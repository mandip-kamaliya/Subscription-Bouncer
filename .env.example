# Wallet private key for PinionOS payment verification (must start with 0x)
# Use a testnet wallet with Base Sepolia ETH for gas and USDC for payments
PINION_PRIVATE_KEY=0x...

# Target API URL to proxy requests to
TARGET_URL=http://localhost:3000

# Price per API call in USDC (use small amounts for testing)
PRICE=0.01

# Wallet address to receive USDC payments (must start with 0x)
# This should be the same wallet as the private key above
WALLET_ADDRESS=0x...

# Port for Subscription Bouncer to run on
PORT=4000

# Network configuration (Base Sepolia testnet)
NETWORK=base-sepolia

# Optional: Custom RPC URL for Base Sepolia
# BASE_SEPOLIA_RPC=https://sepolia.base.org
