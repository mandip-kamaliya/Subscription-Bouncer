{
  "name": "subscription-bouncer",
  "version": "1.0.0",
  "description": "Reverse proxy middleware that monetizes APIs with micropayments",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "subscription-bouncer": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "node --loader ts-node/esm src/index.ts",
    "cli": "node --loader ts-node/esm src/cli.ts",
    "start": "node dist/index.js"
  },
  "keywords": [
    "proxy",
    "micropayments",
    "api",
    "x402",
    "pinionos",
    "base",
    "blockchain"
  ],
  "author": "Hackathon Team",
  "license": "MIT",
  "dependencies": {
    "commander": "^14.0.3",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "http-proxy-middleware": "^2.0.6",
    "pinion-os": "^0.4.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/node": "^20.4.5",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.6"
  },
  "ts-node": {
    "esm": true,
    "experimentalSpecifierResolution": "node"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mandip-kamaliya/Subscription-Bouncer.git"
  },
  "bugs": {
    "url": "https://github.com/mandip-kamaliya/Subscription-Bouncer/issues"
  },
  "homepage": "https://github.com/mandip-kamaliya/Subscription-Bouncer#readme"
}
